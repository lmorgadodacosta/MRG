爸_n_1 := n_-_h_le &
"""
[bàba] father; dad; pa; papa;
"""
  [ STEM < "爸" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爸", LENGTH one ],
    SYNSEM.LKEYS.KEYREL.PRED "_爸_n_1_rel",
    TRAITS native_token_list ].


;================================
; HSK1_WID5: 吧 [ba]
;================================
吧_crs := crs_le &
"""
[ba] sentence final particle indicating suggestion or surmise;

<ex> 咱们 去 吃 饭 吧 。 (Let us go to dinner.)
<ex> 给 我 两 个 吧 。 (Give me two, ok?)
"""
  [ STEM <"吧">,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "吧", LENGTH one ],
    TRAITS native_token_list ].


