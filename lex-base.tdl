;================================
; HSK1_WID9: 班 [bān]
;================================
班_n_1 := n_-_le &
"""
[bān] team; class; grade; military squad; work shift

LMC: removed isntance inheriting from n_-_l_pn_le. From my understanding both types should be mutually exclusive. 
"""
  [ STEM < "班" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "班", LENGTH one ],
    SYNSEM.LKEYS.KEYREL.PRED "_班_n_1_rel",
    TRAITS native_token_list ].

;================================
; HSK1_WID10: 半 [bàn]
;================================
半_n_1 := n_-_indef-pr_le &
"""
[bàn] half; semi-; incomplete; (after a number) and a half;

[FIXME] There is a lot that must be improved with numbers, time expressions and fractions -- all of which require 半 to work properly;
"""
  [ STEM < "半" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "半", LENGTH one ],
    SYNSEM.LKEYS.ALTKEYREL.PRED "_半_n_rel",
    TRAITS native_token_list ].



