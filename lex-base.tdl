;;; -*- Mode: TDL; Coding: utf-8 -*-

;================================================================================
; LEX-BASE.TDL
; 
; This file contains the lexicon listed in the New HSK organized by HSK levels.
; (http://www.moe.gov.cn/jyb_xwfb/gzdt_gzdt/s5987/202103/t20210329_523304.html)
; Taken from: https://github.com/elkmovie/hsk30/blob/main/wordlist.txt
;
; In total this comprises approximately 11,000 surface forms.
;
; HSK 1: 500 surface forms
; HSK 2: 772 surface forms
; HSK 3: 973 surface forms
; HSK 4: 1000 surface forms
; HSK 5: 1071 surface forms
; HSK 6: 1140 surface forms
; HSK 7-8-9: 5636 surface forms
; Total: 11092 surface forms
;================================================================================

;================================================================================
; NEW HSK 1 (500 words)
;================================================================================

;================================
; HSK1_WID1: 爱 [ài]
;================================
爱_v_1 :=  v_np-spr_le &
"""
[ài] to love; to like; to be fond of;
"""
  [ STEM < "爱" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH one ],
    SYNSEM [ LKEYS.KEYREL.PRED "_爱_v_1_rel" ],
    TRAITS native_token_list ].

爱_v_2 := v_vp_sequi-spr_le &
"""
[ài] to be inclined (to do sth);
"""
  [ STEM < "爱" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH one ],
    SYNSEM.LKEYS.KEYREL.PRED "_爱_v_2_rel",
    TRAITS native_token_list ].

爱_n_1 := n_-_le &
"""
[ài] love; affection;
"""
  [ STEM < "爱" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH one ],
    SYNSEM.LKEYS.KEYREL.PRED "_爱_n_1_rel",
    TRAITS native_token_list ].

爱_n_2 := n_-_pn_le &
"""
[ài] common proper name;
"""
  [ STEM < "爱" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH one ],
    SYNSEM.LKEYS.KEYREL.CARG "爱",
    TRAITS native_token_list ].


;================================
; HSK1_WID2: 爱好 [ài hào]
;================================
爱好_n_1 := n_-_c_le &
"""
[ài hào] hobby; interest;
"""
  [ STEM < "爱好" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH two ],
    SYNSEM.LKEYS.KEYREL.PRED "_爱好_n_1_rel", 
    TRAITS native_token_list ].

爱好_v_1 := v_np-spr_le &
"""
[ài hào] to like; to be fond of; to be interested (as a hobby) in;
"""
  [ STEM < "爱好" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_爱好_v_1_rel" ], 
    TRAITS native_token_list ].

爱好_v_2 := v_vp_sequi-spr_le &
"""
[ài hào] to like; to be fond of; to be interested (as a hobby) in;

<ex> 我 很 爱好 骑 自行车 。  (I'm very keen on cycling.)

This was changed to sequi-spr because it allows intensifiers.
"""
  [ STEM < "爱好" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "爱", LENGTH two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_爱好_v_2_rel" ], 
    TRAITS native_token_list ].


